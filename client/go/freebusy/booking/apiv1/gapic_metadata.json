              ]
            },
            "ConfirmBooking": {
              "methods": [
                "ConfirmBooking"
              ]
            },
            "CreateBooking": {
              "methods": [
                "CreateBooking"
              ]
            },
            "GetBooking": {
              "methods": [
                "GetBooking"
              ]
            },
            "ListBookings": {
              "methods": [
                "ListBookings"
              ]
            },
            "PreviewCancellation": {
              "methods": [
                "PreviewCancellation"
              ]
            },
            "RescheduleBooking": {
              "methods": [
                "RescheduleBooking"
              ]
            }
          }
        }
      }
    }
  }
}
