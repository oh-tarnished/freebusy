{
  "methodConfig": [
    {
      "name": [
        { "service": "freebusy.availability.v1.AvailabilityService" },
        { "service": "freebusy.booking.v1.BookingService" },
        { "service": "freebusy.organisation.v1.OrganisationService" },
        { "service": "freebusy.identity.v1.IdentityService" },
        { "service": "freebusy.resource.v1.ResourceService" },
        { "service": "freebusy.promocode.v1.PromoCodeService" },
        { "service": "freebusy.schedule.v1.ScheduleService" }
      ],
      "timeout": "30s",
      "retryPolicy": {
        "maxAttempts": 5,
        "initialBackoff": "0.1s",
        "maxBackoff": "60s",
        "backoffMultiplier": 2.0,
        "retryableStatusCodes": [
          "UNAVAILABLE",
          "DEADLINE_EXCEEDED"
        ]
      }
    }
  ]
}
