# @generated by tools/protobuf/envoy — DO NOT EDIT
# Re-generate with `just gen envoy` (or `just gen`).
# Source: {{.Source}}
#
# Envoy proxy: browser (grpc-web / HTTP 1.1) → freebusy gRPC backend (HTTP/2).
# All freebusy services live on one gRPC backend, so every route targets the
# single {{.ClusterName}} cluster.
# Listener: 0.0.0.0:{{.ListenPort}}
# Admin UI:  0.0.0.0:{{.AdminPort}}

admin:
  address:
    socket_address:
      address: 0.0.0.0
      port_value: {{.AdminPort}}

static_resources:

  listeners:
    - name: grpc_web_listener
      address:
        socket_address:
          address: 0.0.0.0
          port_value: {{.ListenPort}}
      filter_chains:
        - filters:
            - name: envoy.filters.network.http_connection_manager
              typed_config:
                "@type": type.googleapis.com/envoy.extensions.filters.network.http_connection_manager.v3.HttpConnectionManager
                codec_type: AUTO
                stat_prefix: grpc_web
                route_config:
                  name: local_route
                  virtual_hosts:
                    - name: freebusy_services
                      domains: ["*"]
                      routes:
{{range .Services}}
                        - match:
                            prefix: "{{.Prefix}}"
                          route:
                            cluster: {{$.ClusterName}}
                            timeout: {{$.Timeout}}
{{end}}
                      cors:
                        allow_origin_string_match:
                          - prefix: "*"
                        allow_methods: GET, PUT, DELETE, POST, OPTIONS
                        allow_headers: >-
                          keep-alive,user-agent,cache-control,content-type,content-transfer-encoding,
                          x-accept-content-transfer-encoding,x-accept-response-streaming,
                          x-user-agent,x-grpc-web,grpc-timeout,authorization
                        expose_headers: grpc-status,grpc-message,grpc-status-details-bin
                        max_age: "1728000"
                http_filters:
                  - name: envoy.filters.http.grpc_web
                    typed_config:
                      "@type": type.googleapis.com/envoy.extensions.filters.http.grpc_web.v3.GrpcWeb
                  - name: envoy.filters.http.cors
                    typed_config:
                      "@type": type.googleapis.com/envoy.extensions.filters.http.cors.v3.CorsPolicy
                  - name: envoy.filters.http.router
                    typed_config:
                      "@type": type.googleapis.com/envoy.extensions.filters.http.router.v3.Router

  clusters:

    - name: {{.ClusterName}}
      connect_timeout: 5s
      type: STRICT_DNS
      # STRICT_DNS defaults to AUTO, which prefers AAAA. Inside Docker that
      # resolves the backend host to a non-routable IPv6 and every request dies
      # with "Network is unreachable". Pin the family.
      dns_lookup_family: {{.DNSLookupFamily}}
      http2_protocol_options: {}
      lb_policy: ROUND_ROBIN
{{- if .BackendTLS}}
      # The freebusy gRPC port terminates TLS, so a plaintext upstream is an
      # instant 503 (UF/UPE). The SNI must match a SAN on the backend cert —
      # the mkcert dev cert carries `{{.BackendSNI}}`, not `{{.BackendHost}}` —
      # so the dialled host and the presented server name deliberately differ.
      transport_socket:
        name: envoy.transport_sockets.tls
        typed_config:
          "@type": type.googleapis.com/envoy.extensions.transport_sockets.tls.v3.UpstreamTlsContext
          sni: {{.BackendSNI}}
          common_tls_context:
            alpn_protocols: ["h2"]
            # Envoy's upstream client defaults to a TLS 1.2 ceiling. The Go
            # server negotiates 1.3, so without raising the max it aborts the
            # handshake with TLSV1_ALERT_PROTOCOL_VERSION.
            tls_params:
              tls_minimum_protocol_version: TLSv1_2
              tls_maximum_protocol_version: TLSv1_3
{{- end}}
      load_assignment:
        cluster_name: {{.ClusterName}}
        endpoints:
          - lb_endpoints:
              - endpoint:
                  address:
                    socket_address:
                      address: {{.BackendHost}}
                      port_value: {{.BackendPort}}
